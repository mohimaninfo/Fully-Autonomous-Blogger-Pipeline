  <!-- FIREBASE SDK + LIKE/REACTION SYSTEM                    -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <script type='module'>
    import { initializeApp } from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js';
    import { getDatabase, ref, runTransaction, onValue, get } from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-database.js';

    const firebaseConfig = {
      apiKey: "YOUR_FIREBASE_API_KEY",
      authDomain: "YOUR_PROJECT.firebaseapp.com",
      databaseURL: "https://YOUR_PROJECT-default-rtdb.firebaseio.com",
      projectId: "YOUR_PROJECT",
      storageBucket: "YOUR_PROJECT.appspot.com",
      messagingSenderId: "YOUR_SENDER_ID",
      appId: "YOUR_APP_ID"
    };

    const app = initializeApp(firebaseConfig);
    const db = getDatabase(app);

    // Get post ID from URL
    const postId = window.location.pathname.replace(/[^a-zA-Z0-9]/g, '-').replace(/^-+|-+$/g, '');

    const reactions = ['like', 'insightful', 'helpful'];

    // Load current counts from Firebase
    reactions.forEach(reaction => {
      const countRef = ref(db, `reactions/${postId}/${reaction}`);
      onValue(countRef, (snapshot) => {
        const count = snapshot.val() || 0;
        const el = document.getElementById(`count-${reaction}`);
        if (el) el.textContent = count;
      });
    });

    // Handle reaction click
    window.handleReaction = function(reaction, btn) {
      const storageKey = `reacted-${postId}-${reaction}`;
      if (localStorage.getItem(storageKey)) {
        // User already reacted — show feedback
        btn.style.borderColor = '#dc2626';
        setTimeout(() => btn.style.borderColor = '', 1000);
        return;
      }

      const countRef = ref(db, `reactions/${postId}/${reaction}`);
      runTransaction(countRef, (current) => (current || 0) + 1)
        .then(() => {
          localStorage.setItem(storageKey, '1');
          btn.classList.add('active');
          btn.style.transform = 'scale(1.05)';
          setTimeout(() => btn.style.transform = '', 300);
        })
        .catch(err => console.error('Reaction error:', err));
    };
  </script>

