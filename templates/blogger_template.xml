          </div>
        </div>
        <!-- Science -->
        <div class='nav-item'>
          <a class='nav-link' href='/search/label/Science'>Science</a>
          <div class='mega-dropdown'>
            <div class='dropdown-header'>Science Topics</div>
            <a class='dropdown-topic' href='/search/label/Space+%26+Astronomy'>Space &amp; Astronomy<small>Latest discoveries</small></a>
            <a class='dropdown-topic' href='/search/label/Climate+%26+Environment'>Climate<small>Research &amp; analysis</small></a>
            <a class='dropdown-topic' href='/search/label/Biology+%26+Life+Sciences'>Biology<small>Life sciences research</small></a>
            <a class='dropdown-topic' href='/search/label/Physics'>Physics<small>Explainers &amp; research</small></a>
            <a class='dropdown-topic' href='/search/label/Neuroscience'>Neuroscience<small>Brain science &amp; guides</small></a>
          </div>
        </div>
        <!-- More dropdown -->
        <div class='nav-item'>
          <a class='nav-link' href='#'>More ▾</a>
          <div class='mega-dropdown'>
            <div class='dropdown-header'>More Genres</div>
            <a class='dropdown-topic' href='/search/label/Lifestyle'>Lifestyle</a>
            <a class='dropdown-topic' href='/search/label/Business'>Business</a>
            <a class='dropdown-topic' href='/search/label/Education'>Education</a>
            <a class='dropdown-topic' href='/search/label/Environment'>Environment</a>
            <a class='dropdown-topic' href='/search/label/Society'>Society</a>
